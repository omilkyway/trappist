{
  "permissions": {
    "allow": [
      "Bash(python trading/*)",
      "Bash(python3 trading/*)",
      "Bash(source .venv/*)",
      "Bash(pip *)",
      "Bash(uv *)",
      "Bash(curl*)",
      "Bash(jq*)",
      "Bash(cat state.json*)",
      "Bash(cat progress.md*)",
      "Bash(cat keys.local.json*)",
      "Read",
      "Write",
      "mcp__binance-futures__*",
      "mcp__fear-greed__*",
      "mcp__gloria-news__*",
      "mcp__tradingview__*"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(sudo*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/statusline.sh",
    "padding": 1
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Scanning the markets",
      "Reading the charts",
      "Checking funding rates",
      "Calculating risk/reward",
      "Sizing the position",
      "Analyzing momentum",
      "Hunting for setups",
      "Watching the order book",
      "Evaluating the regime",
      "Processing market intel",
      "Trailing the stops",
      "Checking drawdown limits",
      "Reviewing past trades",
      "Optimizing entries",
      "Running the numbers"
    ]
  }
}
