# TRAPPIST — Environment Variables
# Copy to .env: cp .env.sample .env

# Binance Futures API (testnet by default)
# Get testnet keys: https://testnet.binancefuture.com
BINANCE_API_KEY=your_testnet_api_key
BINANCE_API_SECRET=your_testnet_secret

# Live mode (uncomment to switch from testnet to live — DANGEROUS)
# LIVE_MODE=true

# Discord notifications (optional)
DISCORD_WEBHOOK_URL=

# CryptoPanic API (free tier)
CRYPTOPANIC_API_KEY=

# Gloria News API
GLORIA_API_TOKEN=

# Scaleway S3 (for Scaleway deployment)
SCW_S3_ACCESS_KEY=
SCW_S3_SECRET_KEY=

# Claude Code auth (for Scaleway deployment)
ANTHROPIC_API_KEY=
CLAUDE_CREDENTIALS_B64=
CLAUDE_CONFIG_B64=
CREDENTIALS_SECRET_ID=
SCW_SECRET_KEY=
